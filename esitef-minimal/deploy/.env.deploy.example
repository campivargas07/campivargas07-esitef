# Copiar con prepare-env.sh (NO commitear .env.deploy)
# SiteGround: Site Tools → Devs → SSH Keys Manager → SSH Credentials

SFTP_HOST=ssh.esitef.com
SFTP_PORT=18765
SFTP_USER=CHANGE_ME
# Clave privada (en disco, chmod 600):
# esitef-minimal/deploy/.ssh/siteground_esitef
# SSH_KEY_PATH se rellena automáticamente en prepare-env.sh

# Passphrase → NUNCA en este archivo. Usar:
#   GitHub Codespaces secret: SSH_KEY_PASSPHRASE
#   o export SSH_KEY_PASSPHRASE='...' en la sesión

REMOTE_THEME_PATH=/home/customer/www/staging3.esitef.com/public_html/online/wp-content/themes/esitef-minimal
STAGING_URL=https://staging3.esitef.com/online
WP_ADMIN_URL=https://staging3.esitef.com/online/wp-admin
