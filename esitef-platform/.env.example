# PostgreSQL (target platform)
DATABASE_URL=postgresql://esitef:esitef@localhost:5433/esitef

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
# Vercel: AUTH_TRUST_HOST=true

# WordPress auth bridge (during migration)
WP_AUTH_BRIDGE_URL=http://localhost:8080/wp-json/esitef/v1/verify-password
WP_AUTH_BRIDGE_SECRET=change-me-in-production

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Sesiones online — Google Calendar (disponibilidad Tomás)
# Calendario compartido con la service account (email del JSON).
GOOGLE_CALENDAR_ID=primary
# JSON en una línea: {"client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n..."}
GOOGLE_SERVICE_ACCOUNT_JSON=

# En desarrollo sin Google Calendar: checkout simulado (sin Stripe). Forzar: true|false
# SESIONES_ONLINE_SIMULATION=true

# PayPal embebido (USD/MXN/ARS/COP) — SDK v6 en modal de cursos
# Requiere "Advanced Credit and Debit Card Payments" en la app PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Opcional alias del Client ID (mismo valor que arriba)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=
# Webhook URL: {AUTH_URL}/api/webhooks/paypal
# Diagnóstico: GET {AUTH_URL}/api/checkout/paypal

# Email (confirmación inscripción presencial). Sin clave = log en servidor.
RESEND_API_KEY=
MAIL_FROM=ESITEF <noreply@esitef.com>

# WordPress MySQL (ETL source — local Docker con dump producción)
WP_MYSQL_HOST=127.0.0.1
WP_MYSQL_PORT=3307
WP_MYSQL_USER=wordpress
WP_MYSQL_PASSWORD=wordpress
WP_MYSQL_DATABASE=wordpress
WP_TABLE_PREFIX=yrc_
