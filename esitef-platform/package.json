{
  "name": "esitef-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @esitef/web",
    "start:local": "docker compose up -d && npm run dev",
    "setup:local": "bash scripts/setup-local.sh",
    "pull:wp-db": "bash scripts/pull-wp-db.sh",
    "build": "npm run build -w @esitef/web",
    "postinstall": "bash scripts/copy-vendor-for-vercel.sh",
    "db:generate": "npm run generate -w @esitef/db",
    "db:migrate": "npm run migrate -w @esitef/db",
    "db:push": "npm run push -w @esitef/db",
    "db:studio": "npm run studio -w @esitef/db",
    "seed": "npx tsx scripts/seed-prototype.ts",
    "reset:checkout": "npx tsx scripts/reset-demo-checkout.ts",
    "audit": "npx tsx scripts/audit-source.ts",
    "etl:extract": "npx tsx packages/etl/src/cli.ts extract",
    "etl:load": "npx tsx packages/etl/src/cli.ts load",
    "etl:reconcile": "npx tsx packages/etl/src/cli.ts reconcile",
    "export:presencial": "php scripts/export-presencial-data.php",
    "export:formaciones": "php scripts/export-formaciones-online.php",
    "export:wp-redirects": "npx tsx scripts/export-wp-redirects.ts",
    "export:yoast-redirects": "php scripts/export-yoast-redirects.php",
    "test:e2e": "npm run test:e2e -w @esitef/web",
    "test:smoke": "npx tsx scripts/smoke-routes.ts",
    "verify:stripe": "npx tsx scripts/verify-stripe-setup.ts",
    "cutover:rehearse": "npx tsx scripts/cutover.ts rehearse",
    "cutover:delta": "npx tsx scripts/cutover.ts delta",
    "cutover:checklist": "npx tsx scripts/cutover.ts checklist"
  },
  "devDependencies": {
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
